# コピーして .env を作成し、実トークンを設定する（.env は git 管理外）
#   cp .env.example .env

# Hugging Face（SAM 3 / Qwen3-VL のダウンロードに使用）
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RunPod API キー（学習・データ生成フリート用。runpod/README_RUNPOD.md 参照）
RUNPOD_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- CVAT (v2.68.0) ---
CVAT_VERSION=v2.68.0
CVAT_HOST=localhost
CVAT_PORT=4810
POSTGRES_VERSION=15-alpine
REDIS_VERSION=7.2.11-alpine
TRAEFIK_VERSION=v3.6
CVAT_SERVER_PROCESSES=2
CVAT_WORKER_IMPORT_PROCESSES=2
CVAT_WORKER_EXPORT_PROCESSES=2
CVAT_WORKER_CHUNKS_PROCESSES=2
CVAT_WORKER_ANNOTATION_PROCESSES=1
CVAT_WORKER_WEBHOOKS_PROCESSES=1
CVAT_WORKER_QUALITY_REPORTS_PROCESSES=1
CVAT_WORKER_CONSENSUS_PROCESSES=1
CVAT_HEALTH_DISK_USAGE_MAX=90
